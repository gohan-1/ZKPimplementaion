ource.","405_NAME":"METHOD_NOT_ALLOWED","406":"Not Acceptable","406_CLASS":"4xx","406_MESSAGE":"The requested resource is capable of generating only content not acceptable according to the Accept headers sent in the request.","406_NAME":"NOT_ACCEPTABLE","407":"Proxy Authentication Required","407_CLASS":"4xx","407_MESSAGE":"The client must first authenticate itself with the proxy.","407_NAME":"PROXY_AUTHENTICATION_REQUIRED","408":"Request Time-out","408_CLASS":"4xx","408_MESSAGE":"The server timed out waiting for the request.","408_NAME":"REQUEST_TIMEOUT","409":"Conflict","409_CLASS":"4xx","409_MESSAGE":"Indicates that the request could not be processed because of conflict in the request, such as an edit conflict between multiple simultaneous updates.","409_NAME":"CONFLICT","410":"Gone","410_CLASS":"4xx","410_MESSAGE":"Indicates that the resource requested is no longer available and will not be available again.","410_NAME":"GONE","411":"Length Required","411_CLASS":"4xx","411_MESSAGE":"The request did not specify the length of its content, which is required by the requested resource.","411_NAME":"LENGTH_REQUIRED","412":"Precondition Failed","412_CLASS":"4xx","412_MESSAGE":"The server does not meet one of the preconditions that the requester put on the request.","412_NAME":"PRECONDITION_FAILED","413":"Request Entity Too Large","413_CLASS":"4xx","413_MESSAGE":"The request is larger than the server is willing or able to process. Previously called \"Request Entity Too Large\".","413_NAME":"REQUEST_ENTITY_TOO_LARGE","414":"Request-URI Too Large","414_CLASS":"4xx","414_MESSAGE":"The URI provided was too long for the server to process.","414_NAME":"REQUEST_URI_TOO_LONG","415":"Unsupported Media Type","415_CLASS":"4xx","415_MESSAGE":"The request entity has a media type which the server or resource does not support.","415_NAME":"UNSUPPORTED_MEDIA_TYPE","416":"Requested Range not Satisfiable","416_CLASS":"4xx","416_MESSAGE":"The client has asked for a portion of the file (byte