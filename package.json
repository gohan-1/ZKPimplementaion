{
  "name": "create-nodejs-express-app",
  "version": "2.0.0",
  "description": "Modern Node.js Express API boilerplate",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "generate": "node cli/index.js",
    "generate:interactive": "node cli/index.js",
    "generate:noble": "KEY_PASSWORD=$KEY_PASSWORD node cli/index.js --generate noble",
    "generate:nacl": "KEY_PASSWORD=$KEY_PASSWORD node cli/index.js --generate nacl",
    "list": "node cli/index.js --list",
    "load": "KEY_PASSWORD=$KEY_PASSWORD node cli/index.js --load",
    "start": "pm2 start ecosystem.config.json --no-daemon",
    "dev": "cross-env NODE_ENV=development  nodemon bin/cli.js ./Project_v1",
    "devs": "cross-env NODE_ENV=development   NODE_NO_WARNINGS=1 nodemon src/index  ",
    "test": "jest -i --colors --verbose --detectOpenHandles",
    "test:watch": "jest -i --watchAll",
    "coverage": "jest -i --coverage",
    "coverage:coveralls": "jest -i --coverage --coverageReporters=text-lcov | coveralls",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check **/*.js",
    "prettier:fix": "prettier --write **/*.js",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:test": "docker-compose -f docker-compose.yml -f docker-compose.test.yml up",
    "prepare": "husky install"
  },
  "keywords": [
    "node",
    "node.js",
    "boilerplate",
    "generator",
    "express",
    "rest",
    "api",
    "mongodb",
    "mongoose",
    "es6",
    "es7",
    "es8",
    "es9",
    "jest",
    "travis",
    "docker",
    "passport",
    "joi",
    "eslint",
    "prettier"
  ],
  "dependencies": {
    "@noble/ed25519": "^3.0.1",
    "@zk-kit/baby-jubjub": "^1.0.3",
    "@zk-kit/eddsa-poseidon": "^1.1.0",
    "babyjubjub": "^1.0.4",
    "bcryptjs": "^3.0.3",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.0.0",
    "express-rate-limit": "^8.3.1",
    "ffjavascript": "^0.3.1",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "joi": "^18.1.1",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.24.0",
    "mongoose": "^9.3.3",
    "morgan": "^1.9.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pm2": "^6.0.14",
    "snarkjs": "^0.7.6",
    "swagger-jsdoc": "^6.0.8",
    "swagger-ui-express": "^5.0.1",
    "tweetnacl": "^1.0.3",
    "validator": "^13.0.0",
    "winston": "^3.2.1",
    "xss-clean": "^0.1.1"
  },
  "devDependencies": {
    "coveralls": "^3.0.7",
    "eslint": "^10.1.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.18.2",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "faker": "^6.6.6",
    "husky": "9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "node-mocks-http": "^1.8.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
